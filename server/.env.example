# Local dev env. Copy to `.env` and adjust.
# compose.yaml exposes Takt PostgreSQL on 55432 to avoid common 5432/5433 services.
TAKT_DATABASE_URL=postgresql+psycopg://takt:takt@localhost:55432/takt
TAKT_GCP_PROJECT=cost-tracker-490815
TAKT_BQ_DATASET=takt
TAKT_BQ_LOCATION=EU
TAKT_GITHUB_ORG=alive-industries
TAKT_LOG_LEVEL=DEBUG
